#!/bin/sh

echo "Running tests before push"

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

case "$(uname -s)" in
    Darwin*|Linux*)
        ./gradlew clean test
        ;;
    MINGW*|MSYS*)
        ./gradlew.bat clean test
        ;;
    *)
        echo "Unknown operating system"
        exit 1
        ;;
esac

TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
    echo "테스트 실패: push가 중단되었습니다."
    exit 1
else
    echo "테스트 성공: push를 진행합니다."
    exit 0
fi
