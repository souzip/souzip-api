<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                    https://hibernate.org/xsd/orm/mapping/mapping-3.1.0.xsd">
    <access>FIELD</access>

    <mapped-superclass class="com.souzip.domain.shared.BaseEntity">
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
            <basic name="updatedAt">
                <column name="updated_at" nullable="false"/>
            </basic>
        </attributes>
    </mapped-superclass>

    <entity class="com.souzip.domain.location.Location">
        <table name="location">
            <unique-constraint name="UK_LOCATION_NAME_ADDRESS">
                <column-name>name</column-name>
                <column-name>address</column-name>
            </unique-constraint>
        </table>
        <attributes>
            <basic name="name">
                <column name="name" nullable="false"/>
            </basic>
            <basic name="address">
                <column name="address" length="500" nullable="false"/>
            </basic>
            <embedded name="coordinate"/>
        </attributes>
    </entity>

    <entity class="com.souzip.domain.file.File">
        <table name="file">
            <unique-constraint name="uq_file_entity_order">
                <column-name>entity_type</column-name>
                <column-name>entity_id</column-name>
                <column-name>display_order</column-name>
            </unique-constraint>
        </table>
        <attributes>
            <basic name="entityType">
                <column name="entity_type" nullable="false" length="20"/>
                <convert converter="com.souzip.domain.file.EntityTypeConverter"/>
            </basic>
            <basic name="entityId">
                <column name="entity_id" nullable="false"/>
            </basic>
            <basic name="storageKey">
                <column name="storage_key" nullable="false"/>
            </basic>
            <basic name="originalName">
                <column name="original_name" nullable="false"/>
            </basic>
            <basic name="fileSize">
                <column name="file_size" nullable="false"/>
            </basic>
            <basic name="contentType">
                <column name="content_type" nullable="false"/>
            </basic>
            <basic name="displayOrder">
                <column name="display_order" nullable="false"/>
            </basic>
        </attributes>
    </entity>

    <entity class="com.souzip.domain.notice.Notice">
        <table name="notice"/>
        <attributes>
            <basic name="title">
                <column name="title" nullable="false" length="200"/>
            </basic>
            <basic name="content">
                <column name="content" nullable="false" column-definition="TEXT"/>
            </basic>
            <basic name="authorId">
                <column name="author_id" nullable="false"/>
            </basic>
            <basic name="status">
                <column name="status" nullable="false" length="20"/>
                <enumerated>STRING</enumerated>
            </basic>
        </attributes>
    </entity>

    <entity class="com.souzip.domain.admin.Admin">
        <table name="admin"/>
        <attributes>
            <id name="id">
                <column name="id" column-definition="uuid" updatable="false" nullable="false"/>
            </id>
            <basic name="username">
                <column name="username" nullable="false" unique="true" length="20"/>
            </basic>
            <basic name="password">
                <column name="password" nullable="false"/>
            </basic>
            <basic name="role">
                <column name="role" nullable="false" length="20"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="lastLoginAt">
                <column name="last_login_at"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
            <basic name="updatedAt">
                <column name="updated_at" nullable="false"/>
            </basic>
        </attributes>
    </entity>

    <entity class="com.souzip.domain.admin.AdminRefreshToken">
        <table name="admin_refresh_token"/>
        <attributes>
            <id name="id">
                <column name="id" column-definition="uuid" updatable="false" nullable="false"/>
            </id>
            <basic name="adminId">
                <column name="admin_id" column-definition="uuid" nullable="false"/>
            </basic>
            <basic name="token">
                <column name="token" nullable="false"/>
            </basic>
            <basic name="expiresAt">
                <column name="expires_at" nullable="false"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
        </attributes>
    </entity>

    <embeddable class="com.souzip.domain.shared.Coordinate">
        <attributes>
            <basic name="latitude">
                <column name="latitude" nullable="false" precision="10" scale="7"/>
            </basic>
            <basic name="longitude">
                <column name="longitude" nullable="false" precision="10" scale="7"/>
            </basic>
        </attributes>
    </embeddable>

</entity-mappings>
