{
  "analysis": {
    "tokenizer": {
      "jaso_search_tokenizer": {
        "type": "jaso_tokenizer",
        "mistype": true,
        "chosung": true
      },
      "jaso_index_tokenizer": {
        "type": "jaso_tokenizer",
        "mistype": true,
        "chosung": true
      },
      "chosung_index_tokenizer": {
        "type": "jaso_tokenizer",
        "mistype": false,
        "chosung": true
      },
      "chosung_search_tokenizer": {
        "type": "jaso_tokenizer",
        "mistype": false,
        "chosung": true
      },
      "ngram_tokenizer": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 3,
        "token_chars": ["letter", "digit"]
      }
    },
    "filter": {
      "korean_synonym": {
        "type": "synonym",
        "synonyms": [
          "한국, 대한민국"
        ]
      },
      "autocomplete_filter": {
        "type": "edge_ngram",
        "min_gram": 2,
        "max_gram": 20
      }
    },
    "analyzer": {
      "korean_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "korean_synonym", "nori_readingform"]
      },
      "jaso_index_analyzer": {
        "type": "custom",
        "tokenizer": "jaso_index_tokenizer"
      },
      "jaso_search_analyzer": {
        "type": "custom",
        "tokenizer": "jaso_search_tokenizer"
      },
      "chosung_index_analyzer": {
        "type": "custom",
        "tokenizer": "chosung_index_tokenizer"
      },
      "chosung_search_analyzer": {
        "type": "custom",
        "tokenizer": "chosung_search_tokenizer"
      },
      "ngram_analyzer": {
        "type": "custom",
        "tokenizer": "ngram_tokenizer",
        "filter": ["lowercase"]
      },
      "autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "autocomplete_filter"]
      },
      "autocomplete_search_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase"]
      }
    }
  },
  "max_ngram_diff": 10
}
